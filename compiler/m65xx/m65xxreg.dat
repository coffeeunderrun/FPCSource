;
; MOS 65xx registers
;
; layout
; <name>,<value>,<stdname>,<stabidx>,<dwarfidx>
;

NO,$00000000,INVALID,0,0

; Main registers
A,$01010000,a,1,1

; Index registers
X,$01030001,x,3,3
Y,$01030002,y,4,4

; Alternate registers
B,$05010000,b,2,2

; Stack Pointer
S,$05030001,s,5,5

; Direct register
D,$05030002,d,6,6

; Bank registers
DBR,$05010003,dbr,7,7
PBR,$05010004,dbr,8,8

; Status register
P,$05010005,p,9,9

; Program counter
PC,$05030006,pc,10,10
